{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Tmdb": {
    "BaseUrl": "https://api.themoviedb.org/3",
    "ApiKey": "",
    "DefaultCountryCode": "US",
    "Language": "en-US",
    "RequestTimeoutSeconds": 10,
    "MaxRetries": 2,
    "BackoffBaseMilliseconds": 200,
    "BackoffJitterMilliseconds": 150
  },
  "Caching": {
    "MovieCatalog": {
      "SearchMinutes": 5,
      "DiscoverMinutes": 10,
      "DetailsMinutes": 30,
      "ProvidersMinutes": 30,
      "SimilarMinutes": 30,
      "GenresMinutes": 120,
      "TrendingMinutes": 15,
      "NowPlayingMinutes": 15
    }
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "AllowedHosts": "*"
}
