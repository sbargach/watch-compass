{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Tmdb": {
    "BaseUrl": "https://api.themoviedb.org/3",
    "ApiKey": "",
    "DefaultCountryCode": "US",
    "Language": "en-US",
    "RequestTimeoutSeconds": 10
  },
  "Caching": {
    "MovieCatalog": {
      "SearchMinutes": 5,
      "DetailsMinutes": 30,
      "ProvidersMinutes": 30,
      "SimilarMinutes": 30,
      "GenresMinutes": 120,
      "TrendingMinutes": 15
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  }
}
